# downstream
# internal local-zone
home.arpa.:53 {
    bind eth0
    loadbalance round_robin
    file /usr/local/etc/coredns/zone/home.arpa home.arpa.
}
internal.:53 {
    bind eth0
    file /usr/local/etc/coredns/zone/internal internal.
}
flets.:53 {
    bind eth0
    loadbalance round_robin
    file /usr/local/etc/coredns/zone/flets flets.
}
ocn.:53 {
    bind eth0
    loadbalance round_robin
    file /usr/local/etc/coredns/zone/ocn ocn.
}
pool.ntp.org.:53 {
    bind eth0
    template ANY ANY {
      answer  "{{ .Name }} 123 IN CNAME ntp.home.arpa."
        authority "{{ .Name }} 123 IN SOA rfc8633.{{ .Zone }} hostmaster.{{ .Zone }} 1 60 1200 604800 60"
    }
    forward . 127.0.6.1:1053
}
html-load.com.:53 {
    import bind_dns64
    loadbalance round_robin
    file /usr/local/etc/coredns/zone/html-load.com html-load.com. {
        fallthrough
    }
    forward . 127.0.255.0:1153 {
        except fb.html-load.com.
    }
    forward . 127.0.6.1:1053
}
