        except fb.html-load.com.
    }
    forward . 127.0.6.1:1053
}

# global local-zone
5ch.net.:53 2ch.net.:53 {
    bind eth0
    template IN HTTPS {
      match "(\w+)\.[25]ch\.net\.$"  
      answer  "{{ index .Match 1 }}.{{ .Zone }} 900 IN HTTPS 0 {{ index .Match 1 }}.5ch.io."
        authority "{{ .Name }} 900 IN SOA rfc9460.{{ .Zone }} hostmaster.{{ .Zone }} 1 60 1200 604800 60"
    }
    template ANY ANY {
        authority "{{ .Name }} 900 {{ .Class }} SOA rfc9460.{{ .Zone }} hostmaster.{{ .Zone }} 1 60 1200 604800 60"
    }
}
